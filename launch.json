{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "pwa-chrome",
      "request": "launch",
      "name": "Abrir Profe Caimán con Live Server",
      "url": "http://127.0.0.1:5500/index.html",
      "webRoot": "${workspaceFolder}",
      "userDataDir": "${workspaceFolder}/.vscode/chrome-profile"
    },
    {
      "type": "pwa-chrome",
      "request": "launch",
      "name": "Abrir index.html directo",
      "file": "${workspaceFolder}/index.html",
      "webRoot": "${workspaceFolder}",
      "userDataDir": "${workspaceFolder}/.vscode/chrome-profile-directo"
    }
  ]
}